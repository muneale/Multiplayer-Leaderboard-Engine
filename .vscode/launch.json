{
  "version": "0.2.0",
  "configurations": [
    {
      // Starts postgres + redis via docker compose, then attaches the Go debugger.
      // Set breakpoints anywhere in services/player-service and hit F5.
      "name": "player-service",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/services/player-service/cmd",
      "cwd": "${workspaceFolder}/services/player-service",
      "env": {
        "PORT": "3001",
        "DATABASE_URL": "postgres://postgres:postgres@localhost:5432/leaderboard?sslmode=disable",
        "REDIS_ADDR": "localhost:6379",
        "OTEL_EXPORTER_OTLP_ENDPOINT": "localhost:4317"
      },
      "preLaunchTask": "infra: start"
    },
    {
      "name": "player-service: unit tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/services/player-service/internal/handler",
      "cwd": "${workspaceFolder}/services/player-service",
      "args": ["-v", "-count=1"]
    },
    {
      "name": "player-service: integration tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/services/player-service/internal/repository",
      "cwd": "${workspaceFolder}/services/player-service",
      "buildFlags": "-tags integration",
      "args": ["-v", "-count=1", "-timeout", "120s"],
      "preLaunchTask": "infra: start"
    },
    {
      "name": "score-service",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/services/score-service/cmd",
      "cwd": "${workspaceFolder}/services/score-service",
      "env": {
        "PORT": "3002",
        "KAFKA_BROKERS": "localhost:9094",
        "KAFKA_TOPIC": "score-events",
        "REDIS_ADDR": "localhost:6379",
        "OTEL_EXPORTER_OTLP_ENDPOINT": "localhost:4317"
      },
      "preLaunchTask": "infra: start with kafka"
    },
    {
      "name": "score-service: unit tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/services/score-service/internal/handler",
      "cwd": "${workspaceFolder}/services/score-service",
      "args": ["-v", "-count=1"]
    },
    {
      "name": "ranking-service",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/services/ranking-service/cmd",
      "cwd": "${workspaceFolder}/services/ranking-service",
      "env": {
        "PORT": "3003",
        "KAFKA_BROKERS": "localhost:9094",
        "KAFKA_TOPIC": "score-events",
        "KAFKA_GROUP_ID": "ranking-service",
        "REDIS_ADDR": "localhost:6379",
        "OTEL_EXPORTER_OTLP_ENDPOINT": "localhost:4317"
      },
      "preLaunchTask": "infra: start with kafka"
    },
    {
      "name": "ranking-service: unit tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/services/ranking-service/internal/ranking",
      "cwd": "${workspaceFolder}/services/ranking-service",
      "args": ["-v", "-count=1"]
    }
  ]
}
